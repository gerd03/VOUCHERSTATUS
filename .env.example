PORT=3000
OMADA_CONTROLLER_URL=https://your-controller-openapi-address
OMADA_ID=your-omada-id
OMADA_CLIENT_ID=your-client-id
OMADA_CLIENT_SECRET=your-client-secret
OMADA_AUTH_MODE=client_credentials
OMADA_INSECURE_TLS=true

# For Vercel/cloud deployments when OMADA_CONTROLLER_URL is a private LAN IP.
# Use the Interface Access Address shown in Omada Platform Integration when available.
OMADA_USE_CLOUD_OPENAPI=false
OMADA_CLOUD_REGION=auto
OMADA_CLOUD_CONTROLLER_URL=

# Optional narrowing
OMADA_SITE_ID=
OMADA_SITE_NAME=
OMADA_VOUCHER_GROUP_ID=
OMADA_VOUCHER_GROUP_NAME=

# Optional tuning
OMADA_PAGE_SIZE=50
OMADA_TIMEOUT_MS=20000
SPEEDTEST_EMBED_URL=https://fast.com/
